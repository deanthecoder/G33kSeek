<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="Bg0">#06080E</Color>
    <Color x:Key="Bg1">#0A0F1C</Color>
    <Color x:Key="Bg2">#111A2E</Color>
    <Color x:Key="Text0">#F3F7FF</Color>
    <Color x:Key="Text1">#A4B4D3</Color>
    <Color x:Key="Accent">#6FE7FF</Color>
    <Color x:Key="AccentWarm">#FFD36E</Color>

    <SolidColorBrush x:Key="BrushBg0" Color="{StaticResource Bg0}" />
    <SolidColorBrush x:Key="BrushBg1" Color="{StaticResource Bg1}" />
    <SolidColorBrush x:Key="BrushBg2" Color="{StaticResource Bg2}" />
    <SolidColorBrush x:Key="BrushText0" Color="{StaticResource Text0}" />
    <SolidColorBrush x:Key="BrushText1" Color="{StaticResource Text1}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}" />

    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#00000000" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00000000" />
    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.launcherShell">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EE0A111B" Offset="0" />
        <GradientStop Color="#F2141E32" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="BorderBrush" Value="#5A7AD2FF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="26" />
    <Setter Property="Padding" Value="24" />
    <Setter Property="BoxShadow" Value="0 30 60 0 #60000000" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
  </Style>

  <Style Selector="TextBlock.launcherEyebrow">
    <Setter Property="Foreground" Value="#94C8FF" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="2" />
  </Style>

  <Style Selector="TextBlock.launcherTitle">
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.launcherHint">
    <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
  </Style>

  <Style Selector="Border.searchSurface">
    <Setter Property="Background" Value="#A30A121D" />
    <Setter Property="BorderBrush" Value="#6F6FE7FF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="18,14" />
    <Setter Property="BoxShadow" Value="0 0 24 0 #2200E5FF" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
    <Setter Property="CaretBrush" Value="{StaticResource BrushAccent}" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="SelectionBrush" Value="#557FDFFF" />
  </Style>

  <Style Selector="TextBox.searchBox">
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBox.searchBox:focus">
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBox /template/ Border#borderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
  </Style>

  <Style Selector="TextBox:focus /template/ Border#borderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
  </Style>

  <Style Selector="TextBox.searchBox /template/ Border#BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
  </Style>

  <Style Selector="TextBox.searchBox:focus /template/ Border#BorderElement">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
  </Style>

  <Style Selector="TextBox.searchBox /template/ Grid#UnderlineContainer">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="TextBox.searchBox:focus /template/ Grid#UnderlineContainer">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="Border.resultsPanel">
    <Setter Property="Background" Value="#5C09111B" />
    <Setter Property="BorderBrush" Value="#2C7AD2FF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="#1F1F3553" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2A6FE7FF" Offset="0" />
        <GradientStop Color="#12000000" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.resultSubtitle">
    <Setter Property="Foreground" Value="{StaticResource BrushText1}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="TextBlock.resultPrefix">
    <Setter Property="Foreground" Value="#FFD36E" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="#F20A1320" />
    <Setter Property="BorderBrush" Value="#5A87B8D8" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="MenuItem:pointerover">
    <Setter Property="Background" Value="#1E163148" />
  </Style>
</Styles>
