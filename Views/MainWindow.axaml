<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:G33kSeek.ViewModels"
        mc:Ignorable="d"
        x:Class="G33kSeek.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="760"
        Height="560"
        MinWidth="760"
        MinHeight="560"
        MaxWidth="760"
        MaxHeight="560"
        Background="Transparent"
        BorderBrush="Transparent"
        BorderThickness="0"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Icon="/Assets/app.ico"
        Padding="0"
        ShowInTaskbar="False"
        TransparencyBackgroundFallback="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        Topmost="True"
        Title="G33kSeek">
  <Design.DataContext>
    <viewModels:MainWindowViewModel />
  </Design.DataContext>

  <Border Classes="launcherShell"
          Background="#E0000000"
          ClipToBounds="True"
          Margin="18"
          Padding="0"
          VerticalAlignment="Top">
    <Grid>
      <Border>
        <Border.Background>
          <ImageBrush Source="/Assets/main-window-bg.jpg"
                      Opacity="0.25"
                      AlignmentY="Top"
                      Stretch="None" />
        </Border.Background>
      </Border>

      <Grid Margin="18"
            RowDefinitions="Auto,Auto,Auto">
        <StackPanel Margin="0,0,0,14"
                    Spacing="6">
          <TextBlock Classes="launcherEyebrow"
                     Text="KEYBOARD LAUNCHER" />
          <TextBlock Classes="launcherTitle"
                     Text="G33kSeek" />
          <TextBlock Classes="launcherHint"
                     Text="{Binding StatusText}" />
        </StackPanel>

        <Border Grid.Row="1"
                Classes="searchSurface">
          <TextBox x:Name="SearchTextBox"
                   Background="Transparent"
                   BorderThickness="0"
                   Classes="searchBox"
                   FontSize="24"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   Watermark="Type to search files, apps, commands, or the web..." />
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                MaxHeight="{Binding ResultsPanelMaxHeight}"
                Opacity="{Binding ResultsPanelOpacity}"
                IsVisible="{Binding HasResults}"
                Classes="resultsPanel">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="MaxHeight"
                                Duration="0:0:0.18" />
              <DoubleTransition Property="Opacity"
                                Duration="0:0:0.12" />
            </Transitions>
          </Border.Transitions>
          <ListBox x:Name="ResultsListBox"
                   Background="Transparent"
                   BorderThickness="0"
                   ItemsSource="{Binding Results}"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   SelectedItem="{Binding SelectedResult, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="*,Auto"
                      Margin="2"
                      Tapped="OnResultTappedAsync">
                  <StackPanel Spacing="2">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding Title}" />
                    <TextBlock Classes="resultSubtitle"
                               Text="{Binding Subtitle}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Classes="resultPrefix"
                             Text="{Binding TrailingText}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
